#!/usr/bin/env bash

set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=bin/wt-lib
source "$script_dir/wt-lib"

usage() {
  echo "usage: $(basename "$0") <branch> [bucket-dir]" >&2
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage
  exit 0
fi

if [[ $# -lt 1 || $# -gt 2 ]]; then
  usage
  exit 1
fi

branch="$1"
bucket="${2:-$(wt_default_bucket)}"
dir_name="${branch//\//-}"
target_dir="$bucket/$dir_name"

git -C "$wt_repo_root" worktree remove "$target_dir"
git -C "$wt_repo_root" branch -d "$branch"

echo "Removed worktree:"
echo "  branch: $branch"
echo "  path:   $target_dir"
