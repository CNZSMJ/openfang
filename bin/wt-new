#!/usr/bin/env bash

set -euo pipefail

usage() {
  echo "usage: $(basename "$0") <branch> [base-branch] [bucket-dir]" >&2
}

if [[ $# -lt 1 || $# -gt 3 ]]; then
  usage
  exit 1
fi

branch="$1"
base="${2:-custom/0.1.0}"

git_common_dir="$(git rev-parse --path-format=absolute --git-common-dir)"
repo_root="$(dirname "$git_common_dir")"
repo_parent="$(dirname "$repo_root")"
bucket="${3:-$repo_parent/openfang-0.1.0}"
dir_name="${branch//\//-}"
target_dir="$bucket/$dir_name"

mkdir -p "$bucket"

git -C "$repo_root" worktree add "$target_dir" -b "$branch" "$base"

echo "Created worktree:"
echo "  branch: $branch"
echo "  base:   $base"
echo "  path:   $target_dir"
