#!/usr/bin/env bash

set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=bin/wt-lib
source "$script_dir/wt-lib"

usage() {
  echo "usage: $(basename "$0") [head-branch] [base-branch]" >&2
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage
  exit 0
fi

if [[ $# -gt 2 ]]; then
  usage
  exit 1
fi

head_branch="${1:-$(git symbolic-ref --quiet --short HEAD)}"
base_branch="${2:-$(wt_default_base_branch)}"
remote="$(wt_default_remote)"

if [[ -z "$head_branch" ]]; then
  echo "Could not determine current branch." >&2
  exit 1
fi

repo_slug="$(wt_repo_slug_from_remote "$remote")"

git -C "$wt_repo_root" fetch "$remote" "$base_branch" "$head_branch" >/dev/null 2>&1 || true

if ! git -C "$wt_repo_root" rev-parse --verify --quiet "refs/remotes/$remote/$head_branch" >/dev/null; then
  git -C "$wt_repo_root" push -u "$remote" "$head_branch"
fi

gh_args=(pr create --base "$base_branch" --head "$head_branch" --fill)

if [[ -n "$repo_slug" ]]; then
  gh_args+=(-R "$repo_slug")
fi

gh "${gh_args[@]}"
