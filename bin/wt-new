#!/usr/bin/env bash

set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=bin/wt-lib
source "$script_dir/wt-lib"

usage() {
  echo "usage: $(basename "$0") <branch> [base-branch] [bucket-dir]" >&2
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage
  exit 0
fi

if [[ $# -lt 1 || $# -gt 3 ]]; then
  usage
  exit 1
fi

branch="$1"
base="${2:-$(wt_default_base_branch)}"
bucket="${3:-$(wt_default_bucket)}"
dir_name="${branch//\//-}"
target_dir="$bucket/$dir_name"

mkdir -p "$bucket"

git -C "$wt_repo_root" worktree add "$target_dir" -b "$branch" "$base"

echo "Created worktree:"
echo "  branch: $branch"
echo "  base:   $base"
echo "  path:   $target_dir"
