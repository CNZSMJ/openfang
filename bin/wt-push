#!/usr/bin/env bash

set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=bin/wt-lib
source "$script_dir/wt-lib"

usage() {
  echo "usage: $(basename "$0") [branch] [remote]" >&2
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage
  exit 0
fi

if [[ $# -gt 2 ]]; then
  usage
  exit 1
fi

branch="${1:-$(git symbolic-ref --quiet --short HEAD)}"
remote="${2:-$(wt_default_remote)}"

if [[ -z "$branch" ]]; then
  echo "Could not determine current branch." >&2
  exit 1
fi

git -C "$wt_repo_root" push -u "$remote" "$branch"
