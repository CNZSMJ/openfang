#!/usr/bin/env bash

set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=bin/wt-lib
source "$script_dir/wt-lib"

usage() {
  echo "usage: $(basename "$0") <branch> [bucket-dir] [remote]" >&2
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage
  exit 0
fi

if [[ $# -lt 1 || $# -gt 3 ]]; then
  usage
  exit 1
fi

branch="$1"
bucket="${2:-$(wt_default_bucket)}"
remote="${3:-$(wt_default_remote)}"
dir_name="${branch//\//-}"
target_dir="$bucket/$dir_name"

mkdir -p "$bucket"

if [[ -e "$target_dir" ]]; then
  echo "Target path already exists: $target_dir" >&2
  exit 1
fi

if git -C "$wt_repo_root" show-ref --verify --quiet "refs/heads/$branch"; then
  git -C "$wt_repo_root" worktree add "$target_dir" "$branch"
  echo "Opened worktree from local branch:"
  echo "  branch: $branch"
  echo "  path:   $target_dir"
  exit 0
fi

if ! git -C "$wt_repo_root" ls-remote --exit-code --heads "$remote" "$branch" >/dev/null 2>&1; then
  echo "Remote branch not found: $remote/$branch" >&2
  exit 1
fi

git -C "$wt_repo_root" fetch "$remote" "$branch"
git -C "$wt_repo_root" branch --track "$branch" "$remote/$branch"
git -C "$wt_repo_root" worktree add "$target_dir" "$branch"

echo "Opened worktree from remote branch:"
echo "  branch: $branch"
echo "  remote: $remote"
echo "  path:   $target_dir"
