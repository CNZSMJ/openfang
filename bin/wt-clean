#!/usr/bin/env bash

set -euo pipefail

usage() {
  echo "usage: $(basename "$0") <branch> [bucket-dir] [remote]" >&2
}

if [[ $# -lt 1 || $# -gt 3 ]]; then
  usage
  exit 1
fi

branch="$1"

git_common_dir="$(git rev-parse --path-format=absolute --git-common-dir)"
repo_root="$(dirname "$git_common_dir")"
repo_parent="$(dirname "$repo_root")"
bucket="${2:-$repo_parent/openfang-0.1.0}"
remote="${3:-origin}"
dir_name="${branch//\//-}"
target_dir="$bucket/$dir_name"

if git -C "$repo_root" worktree list --porcelain | grep -Fq "worktree $target_dir"; then
  git -C "$repo_root" worktree remove "$target_dir"
  echo "Removed worktree path: $target_dir"
else
  echo "Worktree path not registered: $target_dir"
fi

if ! git -C "$repo_root" show-ref --verify --quiet "refs/heads/$branch"; then
  echo "Local branch not found: $branch"
  exit 0
fi

if git -C "$repo_root" branch -d "$branch"; then
  echo "Deleted local branch: $branch"
  exit 0
fi

if git -C "$repo_root" ls-remote --exit-code --heads "$remote" "$branch" >/dev/null 2>&1; then
  echo "Refusing to force-delete local branch while $remote/$branch still exists." >&2
  echo "Delete or merge the remote branch first, or remove it manually if you really want to discard it." >&2
  exit 1
fi

git -C "$repo_root" branch -D "$branch"
echo "Deleted local branch with -D because $remote/$branch no longer exists."
